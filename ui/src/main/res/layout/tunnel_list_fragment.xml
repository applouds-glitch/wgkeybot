<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/main_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- Статус -->
            <!-- Статус / Статистика — всё в одном блоке вверху -->
            <TextView
                android:id="@+id/vpn_status_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Статус"
                android:textSize="14sp"
                android:letterSpacing="0.05"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/vpn_status_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="32dp"
                android:text="Отключено"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"
                android:textColor="?attr/colorOnSurface" />

            <!-- Кнопка с кольцами -->
            <FrameLayout
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_gravity="center"
                android:id="@+id/button_container">

                <!-- Внешнее кольцо -->
                <View
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    android:layout_gravity="center"
                    android:background="@drawable/ring_outer" />

                <!-- Среднее кольцо -->
                <View
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_gravity="center"
                    android:background="@drawable/ring_middle" />

                <!-- Сама кнопка -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/vpn_toggle_button"
                    style="@style/Widget.Material3.Button.ElevatedButton"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center"
                    android:text=""
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:icon="@drawable/ic_vpn_arrow"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="48dp"
                    app:iconTint="@android:color/white"
                    app:backgroundTint="?attr/colorPrimary"
                    app:cornerRadius="80dp"
                    app:elevation="8dp"
                    app:pressedTranslationZ="0dp" />

            </FrameLayout>

            <!-- Подсказка под кнопкой -->
            <TextView
                android:id="@+id/vpn_hint_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Нажмите для подключения"
                android:textSize="15sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center" />


            <!-- Нет ключа -->
            <TextView
                android:id="@+id/bot_link_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:visibility="gone"
                android:text="Ключ не найден.\nПолучите его в боте:"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.4"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/bot_link_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:visibility="gone"
                android:text="@wg_key_bot"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="16dp"
                android:paddingVertical="10dp" />

        </LinearLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>